FROM rust:1.97-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    pkg-config \
    libssl-dev \
    git \
    curl \
    ca-certificates \
    jq \
    ripgrep \
    clang \
    libdbus-1-dev \
    libgtk-3-dev \
    libx11-dev \
    libxrandr-dev \
    libxi-dev \
    libxxf86vm-dev \
    libgl1-mesa-dev \
    libasound2-dev \
    libudev-dev \
    cmake \
    && rm -rf /var/lib/apt/lists/*

RUN rustup component add rustfmt clippy

RUN cargo install cargo-llvm-cov --locked || true
RUN cargo install cargo-mutants --locked || true

WORKDIR /workspace

CMD ["bash"]